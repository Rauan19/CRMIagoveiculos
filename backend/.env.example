PORT=3001

# Docker Compose (raiz do repo): postgres em localhost:5433
# user: crmiago | password: crmiago | db: crmiago
DATABASE_URL="postgresql://crmiago:crmiago@localhost:5433/crmiago?schema=public"

# Importação — se o nome do vendedor na planilha não bater com User.name (opcional se já houver User)
# IMPORT_DEFAULT_SELLER_ID=1

# Só usado quando o banco está sem nenhum User: npm run import:rm:recover cria um vendedor fallback
# IMPORT_SYSTEM_USER_EMAIL=import.revendamais@local.crm
# IMPORT_SYSTEM_USER_PASSWORD=TrocarDepois123

# Recuperação Revenda Mais (npm run import:rm:recover) — pasta padrão backend/services/recupererdoantigo
