{
  "name": "iagoveiculos-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test:db": "node test-connection.js",
    "test:smoke": "node scripts/smoke.js",
    "db:up": "docker compose -f ../docker-compose.yml up -d",
    "db:start": "docker compose -f ../docker-compose.yml start db",
    "db:stop": "docker compose -f ../docker-compose.yml stop db",
    "db:pause": "docker compose -f ../docker-compose.yml pause db",
    "db:unpause": "docker compose -f ../docker-compose.yml unpause db",
    "db:logs": "docker compose -f ../docker-compose.yml logs -f --tail=200 db",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:delete": "docker compose -f ../docker-compose.yml down -v",
    "seed": "node prisma/seed.js",
    "generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
