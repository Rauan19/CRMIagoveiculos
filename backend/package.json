{
  "name": "iagoveiculos-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test:db": "node test-connection.js",
    "test:smoke": "node scripts/smoke.js",
    "db:up": "docker-compose -f ../docker-compose.yml up -d",
    "db:start": "docker-compose -f ../docker-compose.yml start db",
    "db:stop": "docker-compose -f ../docker-compose.yml stop db",
    "db:pause": "docker-compose -f ../docker-compose.yml pause db",
    "db:unpause": "docker-compose -f ../docker-compose.yml unpause db",
    "db:logs": "docker-compose -f ../docker-compose.yml logs -f --tail=200 db",
    "db:down": "docker-compose -f ../docker-compose.yml down",
    "db:delete": "docker-compose -f ../docker-compose.yml down -v",
    "db:migrate": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "generate": "prisma generate",
    "import:clientes-vendedor": "node scripts/importListagemClientesPorVendedor.js",
    "import:clientes:xlsx": "node scripts/importClientesXlsx.js",
    "import:clientes:xlsx:dry": "node scripts/importClientesXlsx.js --dry-run",
    "import:novos": "node scripts/importClientesXlsx.js && node scripts/ensureRevendaMaisImportUser.js && node scripts/importRevendaMaisBatch.js --dir ./services/recuperaressenovos",
    "import:novos:dry": "node scripts/importClientesXlsx.js --dry-run && node scripts/importRevendaMaisBatch.js --dry-run --dir ./services/recuperaressenovos",
    "import:rm:vendidos-cliente": "node scripts/importRevendaMaisVendidosComCliente.js",
    "import:rm:vendidos-dados-venda": "node scripts/importRevendaMaisVendidosDadosVenda.js",
    "import:rm:estoque": "node scripts/importRevendaMaisEstoqueGerencial.js",
    "import:rm:batch": "node scripts/importRevendaMaisBatch.js",
    "import:rm:batch:list": "node scripts/importRevendaMaisBatch.js --list-only",
    "import:rm:recover": "npm run db:migrate && node scripts/ensureRevendaMaisImportUser.js && node scripts/importRevendaMaisBatch.js --dir ./services/recupererdoantigo",
    "import:rm:recover:dry": "npm run db:migrate && node scripts/ensureRevendaMaisImportUser.js && node scripts/importRevendaMaisBatch.js --dry-run --dir ./services/recupererdoantigo",
    "import:rm:estoque-externo": "node scripts/importRevendaMaisEstoqueExterno.js",
    "import:rm:recover:novos": "npm run db:migrate && npm run import:novos",
    "import:rm:recover:novos:dry": "npm run db:migrate && npm run import:novos:dry",
    "import:rm:relacionamento:list": "node scripts/importRecoverRelacionamento.js --list-only",
    "import:rm:relacionamento:dry": "node scripts/importRecoverRelacionamento.js --dry-run",
    "import:rm:recover:relacionamento": "npm run db:migrate && node scripts/importRecoverRelacionamento.js",
    "import:rm:tudo:list": "node scripts/importRecoverTudo.js --list-only",
    "import:rm:tudo:dry": "node scripts/importRecoverTudo.js --dry-run",
    "import:rm:recover:tudo": "npm run db:migrate && node scripts/importRecoverTudo.js",
    "rm:restore": "node scripts/importRevendaMaisBatch.js --dir ./services/recupertodosesserelcionameto",
    "rm:restore:dry": "node scripts/importRevendaMaisBatch.js --dry-run --dir ./services/recupertodosesserelcionameto",
    "import:rm:estoque-doc": "node scripts/importRevendaMaisEstoqueDocumentacao.js",
    "import:rm:aniversariantes": "node scripts/importRevendaMaisAniversariantes.js",
    "import:rm:canal": "node scripts/importRevendaMaisCanalVenda.js",
    "import:rm:fipe": "node scripts/importRevendaMaisEnriquecerFipe.js",
    "import:rm:valor-minimo": "node scripts/importRevendaMaisEnriquecerValorMinimo.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "prisma": "^5.22.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "fast-xml-parser": "^5.5.9",
    "nodemon": "^3.1.4"
  }
}
